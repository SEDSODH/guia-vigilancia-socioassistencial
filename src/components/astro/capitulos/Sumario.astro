---
import SectionHeader from '@/components/astro/layout/SectionHeader.astro'

const items = [
  { href: '#apresentacao', label: '1. Apresentação' },
  { href: '#base-normativa', label: '2. Base Normativa' },
  { href: '#vigilancia-suas', label: '3. A Vigilância Socioassistencial no SUAS' },
  { href: '#formalizacao', label: '4. Formalização da Vigilância Socioassistencial' },
  { href: '#modelo-portaria', label: '5. Modelo de Portaria' },
  { href: '#resolucao-cmas', label: '6. Resolução do CMAS' },
  { href: '#estrutura-equipe', label: '7. Estruturação da Equipe' },
  { href: '#disseminacao-informacao', label: '8. Produção e Disseminação de Informações' },
  { href: '#apoio-planejamento', label: '9. Apoio ao Planejamento Municipal' },
  { href: '#consolidacao', label: '10. Consolidação da Vigilância Socioassistencial' },
  { href: '#consideracoes', label: '11. Considerações Finais' },
  { href: '#referencias', label: '12. Referências Bibliográficas' },
  { href: '#faq', label: '13. Perguntas Frequentes' },
]
---
<section id="sumario" class="animate-slide-left bg-white dark:bg-slate-800 shadow-xl rounded-2xl p-12 md:p-16 print:shadow-none print:rounded-none">
  <div class="flex items-center justify-between mb-6">
    <div>
      <SectionHeader title="Sumário" />
    </div>
    <div class="flex items-center gap-2 text-xs text-slate-400 dark:text-slate-500 bg-slate-50 dark:bg-slate-700 px-3 py-1.5 rounded-full">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span>~30 min de leitura</span>
    </div>
  </div>
  <div class="space-y-1 text-sm">
    {items.map((item) => (
      <a href={item.href} class="flex items-center justify-between py-2 px-4 rounded hover:bg-institucional-lightBlue dark:hover:bg-slate-700 transition group">
        <span class="font-semibold text-slate-700 dark:text-slate-200 group-hover:text-institucional-blue dark:group-hover:text-institucional-blue">{item.label}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-institucional-blue"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    ))}
  </div>
</section>
