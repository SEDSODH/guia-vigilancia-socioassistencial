<style is:global>
  /* ==========================================================
     READING MODE — Visibility & Styling Rules
     Controla layout de scroll contínuo vs. paginação por livro.
     ========================================================== */

  /* --- Scroll mode: layout contínuo padrão --- */
  [data-reading-mode='scroll'] {
    /* layout padrão — sem alterações */
  }

  /* --- Book mode: layout paginado tipo livro --- */
  [data-reading-mode='book'] {
    /* espaço para regras futuras de paginação */
  }

  /* ==========================================================
     READING MODE TOGGLE — Active state via aria-pressed
     ========================================================== */

  #reading-mode-toggle[aria-pressed='true'] {
    @apply bg-institucional-blue text-white border-institucional-blue shadow-sm;
  }
  #reading-mode-toggle[aria-pressed='true']:hover {
    @apply bg-blue-800 border-blue-800;
  }

  #reading-mode-toggle[aria-pressed='false'] {
    @apply bg-white dark:bg-slate-700 text-slate-600 dark:text-slate-300 border-slate-200 dark:border-slate-600;
  }
  #reading-mode-toggle[aria-pressed='false']:hover {
    @apply bg-slate-50 dark:bg-slate-600;
  }

  #reading-mode-toggle {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #reading-mode-toggle:focus-visible {
    @apply outline-none ring-2 ring-institucional-blue/50 ring-offset-2 dark:ring-offset-slate-900;
  }

  @media print {
    #reading-mode-toggle {
      display: none !important;
    }
  }
</style>

<!--
  Script inline executa imediatamente para:
  1. Definir data-reading-mode no <body> antes do paint (evita flash)
  2. Configurar listeners e sincronizar com React via CustomEvent
-->
<script is:inline>
(function() {
  var LS_KEY = 'caderno-reading-mode'

  // --- Inicialização: sempre scroll, só abre livro se clicado ---
  var mode = 'scroll'

  // Aplica atributo imediatamente para evitar flash de conteúdo
  document.body.setAttribute('data-reading-mode', mode)

  // --- Helpers ---
  function updateMode(newMode) {
    if (newMode === mode) return
    mode = newMode

    // Atualiza atributo no body
    document.body.setAttribute('data-reading-mode', mode)
    localStorage.setItem(LS_KEY, mode)

    // Sincroniza estado visual do botão
    syncToggleUI()

    // Dispara evento customizado para componentes React
    window.dispatchEvent(new CustomEvent('reading-mode-change', {
      detail: { mode: mode }
    }))
  }

  function syncToggleUI() {
    var btn = document.getElementById('reading-mode-toggle')
    if (!btn) return

    var isBook = mode === 'book'
    btn.setAttribute('aria-pressed', String(isBook))

    // Mostra/esconde ícones conforme modo ativo
    document.getElementById('reading-mode-icon-scroll').classList.toggle('hidden', isBook)
    document.getElementById('reading-mode-icon-book').classList.toggle('hidden', !isBook)
  }

  // --- Setup após DOM pronto ---
  function setup() {
    syncToggleUI()

    var btn = document.getElementById('reading-mode-toggle')
    if (btn) {
      btn.addEventListener('click', function() {
        updateMode(mode === 'book' ? 'scroll' : 'book')
      })
    }

    // Escuta eventos externos (ex: botão sair do BookViewport) para sincronizar estado
    window.addEventListener('reading-mode-change', function(e) {
      var newMode = e.detail.mode
      if (newMode === mode) return
      mode = newMode
      document.body.setAttribute('data-reading-mode', mode)
      localStorage.setItem(LS_KEY, mode)
      syncToggleUI()
      // Não dispara o evento de novo — só sincroniza estado interno
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup)
  } else {
    setup()
  }
})()
</script>

<!-- ==========================================================
     TOGGLE UI — Botão único fixo ao lado do print-btn
     ========================================================== -->
<button
  id="reading-mode-toggle"
  class="fixed top-4 right-[11.5rem] max-md:right-[6.5rem] z-50 px-3 py-2 gap-1.5 rounded-full bg-white dark:bg-slate-800 shadow-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:scale-105 transition-all duration-300 inline-flex items-center"
  aria-pressed="false"
  aria-label="Alternar modo de leitura: scroll contínuo ou livro paginado"
  title="Modo de leitura: scroll contínuo ou livro paginado"
>
  <!-- Ícone: scroll contínuo (livro fechado) — visível por padrão -->
  <svg
    id="reading-mode-icon-scroll"
    xmlns="http://www.w3.org/2000/svg"
    width="18" height="18"
    viewBox="0 0 24 24"
    fill="none" stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
    <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
  </svg>

  <!-- Ícone: livro paginado (livro aberto) — oculto por padrão -->
  <svg
    id="reading-mode-icon-book"
    xmlns="http://www.w3.org/2000/svg"
    width="18" height="18"
    viewBox="0 0 24 24"
    fill="none" stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    class="hidden"
  >
    <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
    <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
  </svg>
  <span class="max-md:hidden">Leitura</span>
</button>
