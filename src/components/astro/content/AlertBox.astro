---
export interface Props {
  variant?: 'info' | 'success' | 'warning' | 'danger'
  title?: string
  class?: string
}

const { variant = 'info', title, class: className } = Astro.props

const styles: Record<string, { bg: string; border: string; text: string; iconBg: string; iconColor: string; titleAccent: string }> = {
  info: {
    bg: 'bg-gradient-to-br from-blue-50 to-blue-100/80 dark:from-blue-950/40 dark:to-blue-900/30',
    border: 'border-blue-200 dark:border-blue-800',
    text: 'text-blue-800 dark:text-blue-300',
    iconBg: 'bg-gradient-to-br from-blue-100 to-blue-200 dark:bg-transparent dark:border dark:border-blue-700',
    iconColor: 'text-blue-600 dark:text-blue-400',
    titleAccent: 'border-l-blue-500 dark:border-l-blue-400',
  },
  success: {
    bg: 'bg-gradient-to-br from-green-50 to-green-100/80 dark:from-green-950/40 dark:to-green-900/30',
    border: 'border-green-200 dark:border-green-800',
    text: 'text-green-800 dark:text-green-300',
    iconBg: 'bg-gradient-to-br from-green-100 to-green-200 dark:bg-transparent dark:border dark:border-green-700',
    iconColor: 'text-green-600 dark:text-green-400',
    titleAccent: 'border-l-green-500 dark:border-l-green-400',
  },
  warning: {
    bg: 'bg-gradient-to-br from-amber-50 to-amber-100/80 dark:from-amber-950/40 dark:to-amber-900/30',
    border: 'border-amber-200 dark:border-amber-800',
    text: 'text-amber-800 dark:text-amber-300',
    iconBg: 'bg-gradient-to-br from-amber-100 to-amber-200 dark:bg-transparent dark:border dark:border-amber-700',
    iconColor: 'text-amber-600 dark:text-amber-400',
    titleAccent: 'border-l-amber-500 dark:border-l-amber-400',
  },
  danger: {
    bg: 'bg-gradient-to-br from-red-50 to-red-100/80 dark:from-red-950/40 dark:to-red-900/30',
    border: 'border-red-200 dark:border-red-800',
    text: 'text-red-800 dark:text-red-300',
    iconBg: 'bg-gradient-to-br from-red-100 to-red-200 dark:bg-transparent dark:border dark:border-red-700',
    iconColor: 'text-red-600 dark:text-red-400',
    titleAccent: 'border-l-red-500 dark:border-l-red-400',
  },
}

const s = styles[variant]

const icons: Record<string, string> = {
  info: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
  success: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
  warning: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
  danger: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>',
}
---
<div class={`rounded-xl border border-l-4 p-6 flex gap-3 transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-lg ${s.bg} ${s.border} ${s.text} ${className ?? ''}`}>
  <span class={`flex-shrink-0 flex items-center justify-center w-8 h-8 rounded-full ${s.iconBg}`}>
    <span class={s.iconColor} set:html={icons[variant]} />
  </span>
  <div class="flex-1 space-y-2">
    {title && <h4 class={`font-bold text-lg border-l-2 pl-3 ${s.titleAccent}`}>{title}</h4>}
    <slot />
  </div>
</div>
