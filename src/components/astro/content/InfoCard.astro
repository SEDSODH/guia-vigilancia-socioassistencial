---
export interface Props {
  title: string
  accent?: 'blue' | 'green' | 'purple' | 'orange' | 'slate'
  class?: string
}

const { title, accent = 'blue', class: className } = Astro.props

const accentStyles: Record<string, { border: string; bg: string; text: string }> = {
  blue: { border: 'border-institucional-blue dark:border-institucional-blue', bg: 'bg-institucional-lightBlue dark:bg-institucional-lightBlue', text: 'text-institucional-blue dark:text-institucional-lightBlue-foreground' },
  green: { border: 'border-institucional-green dark:border-institucional-green', bg: 'bg-institucional-lightGreen dark:bg-institucional-lightGreen', text: 'text-institucional-green dark:text-institucional-lightGreen-foreground' },
  purple: { border: 'border-purple-600 dark:border-purple-400', bg: 'bg-purple-50 dark:bg-purple-950', text: 'text-purple-600 dark:text-purple-300' },
  orange: { border: 'border-amber-500 dark:border-amber-400', bg: 'bg-amber-50 dark:bg-amber-950', text: 'text-amber-600 dark:text-amber-300' },
  slate: { border: 'border-slate-400 dark:border-slate-600', bg: 'bg-slate-100 dark:bg-slate-800', text: 'text-slate-600 dark:text-slate-300' },
}

const a = accentStyles[accent]
---
<div class={`p-6 rounded-xl border-t-4 shadow-sm bg-white dark:bg-slate-800 ${a.border} ${a.bg} ${className ?? ''}`}>
  <h4 class={`text-lg font-bold mb-3 ${a.text}`}>{title}</h4>
  <div class="text-inherit">
    <slot />
  </div>
</div>
