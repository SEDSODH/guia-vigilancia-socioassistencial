---
export interface Step {
  number: number
  title: string
  description: string
  accent?: 'blue' | 'green' | 'slate'
}

export interface Props {
  steps: Step[]
  class?: string
}

const { steps, class: className } = Astro.props

const icons: Record<string, string> = {
  blue:
    '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',
  green:
    '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
  slate:
    '<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="2" ry="2"/><line x1="10" y1="12" x2="14" y2="12"/><path d="M10 16h4"/><path d="M10 8h4"/></svg>',
}

const badges: Record<string, string> = {
  blue: 'ETAPA',
  green: 'CONCLUSÃO',
  slate: 'DOCUMENTO',
}
---

<div class={`process-stepper-container ${className ?? ''}`}>
  <div class="process-stepper-line" />

  {steps.map((step, index) => {
    const v = step.accent || 'blue'
    return (
      <div class="process-stepper-item animate-slide-down" style={`--delay: ${index * 100}ms`}>
        <div class={`process-stepper-dot dot-${v}`}>
          <span class="dot-number">{step.number}</span>
        </div>
        <div class={`process-stepper-card card-${v}`}>
          <div class={`card-icon icon-${v}`} set:html={icons[v]} />
          <div class="card-body">
            <span class={`badge-variant badge-${v}`}>{badges[v]}</span>
            <div class="card-header">
              <h4 class="card-title">{step.title}</h4>
            </div>
            <p class="card-desc">{step.description}</p>
          </div>
        </div>
      </div>
    )
  })}
</div>

<style>
  /* ============================================ */
  /* ANIMAÇÃO ESCALONADA                          */
  /* ============================================ */

  .animate-slide-down {
    opacity: 0;
    transform: translateY(-20px);
    animation: slideDown 0.5s ease-out forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes slideDown {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ============================================ */
  /* PROCESS STEPPER - ESTRUTURA                  */
  /* ============================================ */

  .process-stepper-container {
    position: relative;
    padding-left: 3.5rem;
  }

  @media (max-width: 767px) {
    .process-stepper-container { padding-left: 2.5rem; }
  }

  .process-stepper-line {
    position: absolute;
    left: 1.75rem;
    top: 0;
    bottom: 0;
    width: 3px;
    border-radius: 2px;
    background: linear-gradient(to bottom, #3b82f6, #22c55e, #64748b);
    transform: translateX(-50%);
  }

  @media (max-width: 767px) {
    .process-stepper-line { left: 1.25rem; }
  }

  .process-stepper-item {
    position: relative;
    margin-bottom: 1.5rem;
  }
  .process-stepper-item:last-child {
    margin-bottom: 0;
  }

  .process-stepper-dot {
    position: absolute;
    left: -2.5rem;
    top: 1.25rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 0 4px white, 0 2px 4px rgb(0 0 0 / 0.15);
  }

  @media (max-width: 767px) {
    .process-stepper-dot { left: -1.75rem; width: 2rem; height: 2rem; }
  }

  .dot-number {
    font-size: 0.8125rem;
    font-weight: 800;
    color: white;
    line-height: 1;
  }

  /* ============================================ */
  /* CARDS - BASE                                 */
  /* ============================================ */

  .process-stepper-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 1.5rem;
    border-radius: 1rem;
    border: 2px solid transparent;
    background: white;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .process-stepper-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1);
  }

  @media (max-width: 767px) {
    .process-stepper-card { padding: 0.75rem 1rem; gap: 0.75rem; }
  }

  /* ============================================ */
  /* ÍCONE DO CARD                                */
  /* ============================================ */

  .card-icon {
    width: 48px;
    height: 48px;
    border-radius: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: white;
  }

  @media (max-width: 767px) {
    .card-icon { width: 40px; height: 40px; border-radius: 0.5rem; }
  }

  /* ============================================ */
  /* CORPO DO CARD                                */
  /* ============================================ */

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    flex: 1;
    min-width: 0;
  }

  .badge-variant {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
    color: white;
  }

  .card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .card-title {
    font-size: 0.875rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.4;
  }

  .card-desc {
    font-size: 0.8125rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }

  /* ============================================ */
  /* VARIANTE: BLUE (ETAPA)                       */
  /* ============================================ */

  .card-blue {
    border-color: #60a5fa;
    background: linear-gradient(135deg, #eff6ff 0%, white 100%);
  }

  .icon-blue {
    background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  }

  .badge-blue {
    background: #3b82f6;
  }

  .card-blue .card-title {
    color: #1d4ed8;
  }

  .dot-blue {
    background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  }

  /* ============================================ */
  /* VARIANTE: GREEN (CONCLUSÃO)                  */
  /* ============================================ */

  .card-green {
    border-color: #4ade80;
    background: linear-gradient(135deg, #f0fdf4 0%, white 100%);
  }

  .icon-green {
    background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
  }

  .badge-green {
    background: #22c55e;
  }

  .card-green .card-title {
    color: #15803d;
  }

  .dot-green {
    background: linear-gradient(135deg, #22c55e 0%, #4ade80 100%);
  }

  /* ============================================ */
  /* VARIANTE: SLATE (DOCUMENTO)                  */
  /* ============================================ */

  .card-slate {
    border-color: #94a3b8;
    background: linear-gradient(135deg, #f8fafc 0%, white 100%);
  }

  .icon-slate {
    background: linear-gradient(135deg, #64748b 0%, #94a3b8 100%);
  }

  .badge-slate {
    background: #64748b;
  }

  .card-slate .card-title {
    color: #334155;
  }

  .dot-slate {
    background: linear-gradient(135deg, #64748b 0%, #94a3b8 100%);
  }

  /* ============================================ */
  /* TEMA ESCURO                                  */
  /* ============================================ */

  :global(.dark) .process-stepper-card {
    background: #1e293b;
    border-color: #334155;
  }

  :global(.dark) .process-stepper-line {
    opacity: 0.6;
  }

  :global(.dark) .process-stepper-dot {
    box-shadow: 0 0 0 4px #0f172a, 0 2px 4px rgb(0 0 0 / 0.4);
  }

  :global(.dark) .card-blue {
    background: linear-gradient(135deg, #1e3a5f 0%, #0f172a 100%);
    border-color: #3b82f6;
  }
  :global(.dark) .card-blue .card-title {
    color: #93c5fd;
  }

  :global(.dark) .card-green {
    background: linear-gradient(135deg, #14532d 0%, #0f172a 100%);
    border-color: #22c55e;
  }
  :global(.dark) .card-green .card-title {
    color: #86efac;
  }

  :global(.dark) .card-slate {
    background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
    border-color: #64748b;
  }
  :global(.dark) .card-slate .card-title {
    color: #cbd5e1;
  }

  :global(.dark) .card-desc {
    color: #94a3b8;
  }
</style>
