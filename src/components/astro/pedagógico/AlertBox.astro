---
export interface Props {
  type: 'danger' | 'warning' | 'success' | 'info'
  title?: string
  icon?: string
  class?: string
}

const { type = 'info', title, icon, class: className } = Astro.props

interface StyleConfig {
  bg: string
  border: string
  text: string
  iconColor: string
}

const styles: Record<string, StyleConfig> = {
  danger: {
    bg: 'bg-red-50 dark:bg-red-950/40',
    border: 'border-red-500 dark:border-red-400',
    text: 'text-red-700 dark:text-red-300',
    iconColor: 'text-red-600 dark:text-red-400',
  },
  warning: {
    bg: 'bg-amber-50 dark:bg-amber-950/40',
    border: 'border-amber-500 dark:border-amber-400',
    text: 'text-amber-700 dark:text-amber-300',
    iconColor: 'text-amber-600 dark:text-amber-400',
  },
  success: {
    bg: 'bg-green-50 dark:bg-green-950/40',
    border: 'border-green-500 dark:border-green-400',
    text: 'text-green-700 dark:text-green-300',
    iconColor: 'text-green-600 dark:text-green-400',
  },
  info: {
    bg: 'bg-blue-50 dark:bg-blue-950/40',
    border: 'border-blue-500 dark:border-blue-400',
    text: 'text-blue-700 dark:text-blue-300',
    iconColor: 'text-blue-600 dark:text-blue-400',
  },
}

const s = styles[type]

const defaultIcons: Record<string, string> = {
  danger:
    '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></svg>',
  warning:
    '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>',
  success:
    '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
  info:
    '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>',
}

const iconHtml = icon || defaultIcons[type]
---

<div
  class={`animate-on-scroll rounded-xl border-l-4 shadow-sm p-5 flex gap-4 transition-all duration-300 hover:shadow-md ${s.border} ${s.bg} ${s.text} ${className ?? ''}`}
>
  <span class={`flex-shrink-0 mt-0.5 ${s.iconColor}`} set:html={iconHtml} />
  <div class="flex-1 space-y-2">
    {title && <h4 class="font-bold text-base">{title}</h4>}
    <slot />
  </div>
</div>
