---
import Card from '@/components/astro/ui/Card.astro'

export interface Props {
  padding?: 'sm' | 'md' | 'lg'
  class?: string
}

const { padding = 'md', class: className } = Astro.props

const paddings: Record<string, string> = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
}
---

<Card class={`${paddings[padding]} ${className ?? ''}`}>
  <slot />
</Card>
