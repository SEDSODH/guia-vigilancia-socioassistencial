---
import '@/styles/global.css'
import ReadingModeToggle from '@/components/astro/layout/ReadingModeToggle.astro'
import { WelcomeModal } from '@/components/react/layout/WelcomeModal'

export interface Props {
  title?: string
  description?: string
}

const { title, description } = Astro.props
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || "Guia de Implantação da Vigilância Socioassistencial nos Municípios - COOVIG/SEDSODH-RJ"} />
    <title>{title || "Guia de Implantação da Vigilância Socioassistencial - SUAS/RJ"}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        var reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        if (reducedMotion) {
          document.documentElement.classList.add('reduce-motion')
        }
        var theme = localStorage.getItem('caderno-theme')
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark')
        }
      })()
    </script>
    <script is:inline>
      (function() {
        var mode = localStorage.getItem('caderno-color-blind')
        if (mode === 'deuteranopia' || mode === 'protanopia' || mode === 'tritanopia') {
          document.documentElement.setAttribute('data-color-blind', mode)
        }
      })()
    </script>
    <style is:inline>
      .reduce-motion .animate-on-scroll,
      .reduce-motion .animate-scale,
      .reduce-motion .animate-slide-left,
      .reduce-motion .animate-slide-right { opacity: 1 !important; transform: none !important; transition: none !important; }
      .reduce-motion .animate-on-scroll > *,
      .reduce-motion .animate-scale > *,
      .reduce-motion .animate-slide-left > *,
      .reduce-motion .animate-slide-right > * { transition-delay: 0ms !important; }
    </style>
  </head>
  <body class="bg-slate-100 dark:bg-slate-900 text-slate-800 dark:text-slate-200 font-sans antialiased transition-colors duration-300">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-6 focus:py-3 focus:bg-institucional-blue focus:text-white focus:rounded-lg focus:shadow-xl focus:outline-none focus:ring-2 focus:ring-institucional-blue/50">Pular para o conteúdo principal</a>
    <div id="top-progress" class="fixed top-0 left-0 h-1 bg-institucional-green z-[60] transition-all duration-150 ease-linear" style="width: 0%"></div>
    <slot />

    <script>
      window.addEventListener('scroll', function() {
        var scrollTop = window.scrollY
        var docHeight = document.documentElement.scrollHeight - window.innerHeight
        var progress = docHeight > 0 ? Math.min((scrollTop / docHeight) * 100, 100) : 0
        var progressEl = document.getElementById('top-progress')
        if (progressEl) progressEl.style.width = progress + '%'
      }, { passive: true })
    </script>

    <script>
      (function() {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible')
            }
          })
        }, { threshold: 0.06, rootMargin: '0px 0px -50px 0px' })

        var animClasses = ['.animate-on-scroll', '.animate-scale', '.animate-slide-left', '.animate-slide-right']
        for (var c = 0; c < animClasses.length; c++) {
          var els = document.querySelectorAll(animClasses[c])
          for (var i = 0; i < els.length; i++) {
            var el = els[i]
            var rect = el.getBoundingClientRect()
            if (rect.top < window.innerHeight && rect.bottom > 0) {
              el.classList.add('visible')
            } else {
              observer.observe(el)
            }
          }
        }
      })()
    </script>

    <ReadingModeToggle />
    <WelcomeModal client:load />
    <button id="theme-toggle" class="fixed top-4 right-4 z-40 px-3 py-2 gap-1.5 rounded-full bg-white dark:bg-slate-800 shadow-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:scale-105 transition-all duration-300 inline-flex items-center" aria-label="Alternar tema">
      <svg id="theme-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg id="theme-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <span>Tema</span>
    </button>

    <button id="print-btn" onclick="window.print()" class="fixed top-4 right-[6.5rem] z-40 px-3 py-2 gap-1.5 rounded-full bg-white dark:bg-slate-800 shadow-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:scale-105 transition-all duration-300 inline-flex items-center" aria-label="Imprimir">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 12H4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-4a2 2 0 0 0-2-2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      <span>PDF</span>
    </button>

    <button id="a11y-toggle" class="fixed top-4 right-[18rem] z-40 px-3 py-2 gap-1.5 rounded-full bg-white dark:bg-slate-800 shadow-lg border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 hover:scale-105 transition-all duration-300 inline-flex items-center" aria-label="Opções de acessibilidade visual" title="Acessibilidade: modos para daltonismo">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
      <span>Acess.</span>
    </button>

    <div id="a11y-dropdown" class="fixed top-16 right-[18rem] z-50 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl p-3 w-56 hidden">
      <p class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-2 px-1">Daltonismo</p>
      <button data-a11y="" class="a11y-option block w-full text-left px-3 py-1.5 rounded text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">Desligado</button>
      <button data-a11y="deuteranopia" class="a11y-option block w-full text-left px-3 py-1.5 rounded text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">Deuteranopia (verde-vermelho)</button>
      <button data-a11y="protanopia" class="a11y-option block w-full text-left px-3 py-1.5 rounded text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">Protanopia (vermelho)</button>
      <button data-a11y="tritanopia" class="a11y-option block w-full text-left px-3 py-1.5 rounded text-xs font-medium text-slate-700 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">Tritanopia (azul-amarelo)</button>
    </div>

    <script>
      (function() {
        var btn = document.getElementById('a11y-toggle')
        var dropdown = document.getElementById('a11y-dropdown')
        if (!btn || !dropdown) return
        var options = dropdown.querySelectorAll('.a11y-option')
        var LS_KEY = 'caderno-color-blind'

        function hideDropdown() { if (dropdown) dropdown.classList.add('hidden') }

        // Highlight current mode
        var current = localStorage.getItem(LS_KEY) || ''
        options.forEach(function(opt) {
          if ((opt.getAttribute('data-a11y') || '') === current) {
            opt.classList.add('bg-institucional-lightBlue', 'dark:bg-institucional-blue/20', 'text-institucional-blue', 'font-bold')
          }
        })

        btn.addEventListener('click', function(e) {
          e.stopPropagation()
          if (dropdown) dropdown.classList.toggle('hidden')
        })

        options.forEach(function(opt) {
          opt.addEventListener('click', function() {
            var mode = opt.getAttribute('data-a11y') || ''
            hideDropdown()
            if (mode) {
              document.documentElement.setAttribute('data-color-blind', mode)
              localStorage.setItem(LS_KEY, mode)
            } else {
              document.documentElement.removeAttribute('data-color-blind')
              localStorage.removeItem(LS_KEY)
            }
            options.forEach(function(o) {
              var active = (o.getAttribute('data-a11y') || '') === mode
              o.classList.toggle('bg-institucional-lightBlue', active)
              o.classList.toggle('dark:bg-institucional-blue/20', active)
              o.classList.toggle('text-institucional-blue', active)
              o.classList.toggle('font-bold', active)
            })
          })
        })

        document.addEventListener('click', function() {
          hideDropdown()
        })
      })()
    </script>

    <script>
      (function() {
        var btn = document.getElementById('theme-toggle')
        var sun = document.getElementById('theme-sun')
        var moon = document.getElementById('theme-moon')
        if (!btn || !sun || !moon) return
        var isDark = document.documentElement.classList.contains('dark')
        function update() {
          if (isDark) { sun?.classList.remove('hidden'); moon?.classList.add('hidden') }
          else { sun?.classList.add('hidden'); moon?.classList.remove('hidden') }
        }
        update()
        btn.addEventListener('click', function() {
          isDark = !isDark
          document.documentElement.classList.toggle('dark', isDark)
          localStorage.setItem('caderno-theme', isDark ? 'dark' : 'light')
          update()
        })
      })()
    </script>
  </body>
</html>
